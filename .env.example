# ═══════════════════════════════════════════════════════════
# QA Triage Dashboard — Environment Variables
# ═══════════════════════════════════════════════════════════
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to source control.
#
# Usage:
#   Windows CMD:   for /f "tokens=*" %a in (.env) do set %a
#   Windows PS:    Get-Content .env | ForEach { if ($_ -match '^[^#]') { $k,$v=$_.split('=',2); [Environment]::SetEnvironmentVariable($k,$v,'Process') } }
#   Linux/Mac:     export $(cat .env | xargs)
# ═══════════════════════════════════════════════════════════

# Azure Cosmos DB
COSMOS_ENDPOINT=https://your-cosmos-account.documents.azure.com:443/
COSMOS_KEY=your-cosmos-db-primary-key
COSMOS_DATABASE=tcaDB
COSMOS_CONTAINER=reg_documents

# Azure DevOps (for bug creation from dashboard)
ADO_PAT=your-azure-devops-personal-access-token
ADO_ORGANIZATION=your-ado-org
ADO_PROJECT=Your%20Project
